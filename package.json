    "fumadocs-mdx": "13.0.5",
    "fumadocs-ui": "16.0.7",
    "jotai": "^2.16.1",
    "lru-cache": "^11.2.5",
    "lucide-react": "^0.562.0",
    "next": "16.1.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
